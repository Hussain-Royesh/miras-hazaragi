# Copy this file to .env.local and fill in your values

# SQL Server — choose the format that matches your setup:

# Option A — Windows Authentication (most common for local SQL Server)
DATABASE_URL="sqlserver://localhost;database=miras;integratedSecurity=true;trustServerCertificate=true"

# Option B — SQL Server Express (named instance)
# DATABASE_URL="sqlserver://localhost\\SQLEXPRESS;database=miras;integratedSecurity=true;trustServerCertificate=true"

# Option C — SQL Auth (sa login or custom user)
# DATABASE_URL="sqlserver://localhost;database=miras;user=sa;password=YourPassword;trustServerCertificate=true"

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Your site URL (no trailing slash)
NEXT_PUBLIC_URL=http://localhost:3000
